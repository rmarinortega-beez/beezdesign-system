{
  "name": "@beez-projects/ui",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
},
  "scripts": {
    "dev": "vite --config vite.app.config.ts",
    "build": "npm run build:app",
    "build:app": "tsc -b && vite build --config vite.app.config.ts",
    "build:lib": "tsc -b && vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "lint": "eslint .",
    "preview": "npm run build:app && vite preview --config vite.app.config.ts",
    "prepack": "npm run build:lib",
    "pack:local": "npm pack"
  },
  "dependencies": {
    "lucide-react": "^1.18.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0 || >=19.0.0",
    "react-dom": ">=18.0.0 || >=19.0.0"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "@tailwindcss/vite": "^4.3.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.2"
  }
}
