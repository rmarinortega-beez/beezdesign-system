# Supabase project credentials
# Copy this file to .env and fill in the real values from your Supabase project settings.
# These values are safe to expose in the browser (anon key uses Row Level Security).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_VAPID_PUBLIC_KEY=your-web-push-public-vapid-key
